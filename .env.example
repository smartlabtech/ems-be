# Application Configuration
NODE_ENV=production
PORT=3000
APP_NAME=2ZPoint
APP_URL=https://your-domain.com

# Database Configuration
MONGO_DATABASE=2zpoint
MONGO_URI=mongodb://app_user:app_password@mongo:27017/2zpoint?authSource=2zpoint

# JWT Configuration
JWT_SECRET=your-strong-jwt-secret-key-here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-strong-refresh-secret-key-here
JWT_REFRESH_EXPIRES_IN=30d

# Email Service Configuration - Mailrelay.com API
MAILRELAY_API_URL=https://example.ipzmarketing.com/api/v1/send_emails  # Replace 'example' with your Mailrelay subdomain
MAILRELAY_AUTH_TOKEN=your-mailrelay-auth-token  # Your Mailrelay API auth token
EMAIL_FROM=noreply@yourdomain.com  # Your verified sender email
EMAIL_FROM_NAME=2ZPoint
EMAIL_VERIFICATION_URL=https://yourdomain.com/verify-email
PASSWORD_RESET_URL=https://yourdomain.com/reset-password

# Legacy SMTP Configuration (can be removed if not needed)
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=your_smtp_password

# Alternative Email Providers (if needed)
EMAIL_SERVICE_PROVIDER=mailrelay  # Options: mailrelay, smtp, sendgrid, mailgun
SENDGRID_API_KEY=your-sendgrid-api-key
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.yourdomain.com

# Firebase Configuration (if using)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# AWS Configuration (if using)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# Zoom API Configuration (if using)
ZOOM_API_KEY=your-zoom-api-key
ZOOM_API_SECRET=your-zoom-api-secret

# OpenAI Configuration (if using)
OPENAI_API_KEY=your-openai-api-key

# SMS Service Configuration (if using)
SMS_SERVICE_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Redis Configuration (if using)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Security
CORS_ORIGIN=https://your-frontend-domain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Docker Compose Specific
APP_PORT=3000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DESTINATION=./uploads

# Session
SESSION_SECRET=your-strong-session-secret-key-here

# Payment Gateway - Ziina
ZIINA_API_URL=https://api-v2.ziina.com/api
ZIINA_ACCESS_TOKEN=your-ziina-access-token
ZIINA_WEBHOOK_SECRET=your-ziina-webhook-secret

# Social Auth (if using)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret