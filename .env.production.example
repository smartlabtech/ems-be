# Production Environment Variables for Coolify

# Application
NODE_ENV=production
PORT=3041

# Database - REQUIRED
# MongoDB connection string
DB_URI=mongodb://username:password@mongodb-host:27017/2zpoint_prod

# JWT - REQUIRED
JWT_SECRET=your-super-secret-jwt-key-here-change-this
JWT_EXPIRES_IN=7d

# CORS - REQUIRED
# Add your production frontend URLs (comma-separated)
# This should be the actual domain where your frontend is hosted
FRONTEND_URL=https://app.2zpoint.com,https://www.2zpoint.com

# Optional
COOKIE_DOMAIN=.2zpoint.com
MAX_REQUEST_SIZE=50mb
MAX_CONTENT_CHARS=80000

# Email Service (if using)
# EMAIL_SERVICE_PROVIDER=sendgrid
# SENDGRID_API_KEY=your-sendgrid-api-key