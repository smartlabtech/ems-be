# Ziina Payment Gateway Configuration

# Ziina API URL
# Production: https://api-v2.ziina.com/api
# Sandbox: https://api-sandbox-v2.ziina.com/api
ZIINA_API_URL=https://api-sandbox-v2.ziina.com/api

# Ziina Access Token
# Get this from your Ziina dashboard
ZIINA_ACCESS_TOKEN=your_ziina_access_token_here

# Ziina Webhook Secret
# Used to verify webhook signatures
ZIINA_WEBHOOK_SECRET=your_webhook_secret_here

# Optional: Ziina Client ID and Secret for OAuth
# ZIINA_CLIENT_ID=your_client_id
# ZIINA_CLIENT_SECRET=your_client_secret